<footer>
    <div class="row g-3 align-items-center">
        <div class="col-12 col-md-4 text-center">
            @* CTA *@
            <img src="images\TheBugTrackerLogoBluV3.png" height="30" />
            <MudText Typo="Typo.body1">
                Learn to build this at
                <MudLink Href="https://coderfoundry.com" Typo="Typo.inherit" Color="Color.Tertiary">coderfoundry.com</MudLink>!
            </MudText>
