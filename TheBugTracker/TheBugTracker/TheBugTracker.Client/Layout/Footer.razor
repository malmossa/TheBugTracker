        <div class="col-12 text-center col-md-4 text-md-end">
            @* Links *@
            <MudLink Href="#" Target="_blank" Typo="Typo.subtitle2" Color="Color.Tertiary">API Spec</MudLink>&bull;
            <MudLink Href="#" Target="_blank" Typo="Typo.subtitle2" Color="Color.Tertiary">Portfolio</MudLink>&bull;
            <MudLink Href="#" Target="_blank" Typo="Typo.subtitle2" Color="Color.Tertiary">Blog</MudLink>
        </div>
        <div class="col-12 text-center col-md-4 text-md-start order-md-first">
            @* Logo + Copyright *@
            <img src="images/CF_Logo_N.png" height="40" />
            <MudText Typo="Typo.body2" Color="Color.Primary">&copy; @DateTime.Now.Year Coder Foundry</MudText>
        </div>
    </div>
